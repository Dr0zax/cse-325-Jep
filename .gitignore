## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Visual Studio cache/options directory
.vs/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# MonoDevelop / Xamarin Studio
*.userprefs

# Build artifacts
*.dll
*.exe
*.pdb
*.cache
*.ilk
*.log

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet
*.nupkg
*.snupkg
packages/
!packages/build/
*.nuget.props
*.nuget.targets

# DotNet CLI tools
.dotnet/

# Publish output
publish/
*.publishproj

# Azure
*.azurePubxml

# Resharper
_ReSharper*/
*.DotSettings.user

# StyleCop
StyleCopReport.xml

# SQL Server files
*.mdf
*.ldf

# Windows image file caches
Thumbs.db
ehthumbs.db

# OS files
.DS_Store
Desktop.ini

# Backup & temp files
*.bak
*.tmp
*.temp

# Logs
*.log

# Environment variables
.env
.env.*

# Coverage reports
coverage/
*.coverage
*.coveragexml

# Generated files
Generated_Code/

# Entity Framework migrations snapshot
*Migrations/*.Designer.cs